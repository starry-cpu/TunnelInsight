# ===================================
# TunnelInsight .gitignore
# 防止敏感信息提交到版本库
# ===================================

# ===== Python =====
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
env/
ENV/
.venv

# ===== Node.js / 前端 =====
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Build output
frontend/dist/
frontend/build/
frontend/.next/
frontend/out/

# ===== 环境变量（重要！）=====
.env
.env.local
.env.development
.env.production
.env.*.local
*.env

# 保留模板文件
!.env.example
!backend/.env.example

# ===== 数据库 =====
*.db
*.sqlite
*.sqlite3
*.sql.bak

# ===== 上传文件 =====
uploads/
backend/uploads/
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.tiff
*.webp

# ===== 日志文件 =====
logs/
*.log
backend/logs/
frontend/logs/

# ===== AI 模型文件（体积大）=====
# LoRA adapter files (通常几百 MB)
backend/models/
src/models/
*.bin
*.safetensors
*.pt
*.pth
*.ckpt
*.h5
*.pkl
*.pickle

# 模型缓存
.cache/
transformers_cache/
huggingface/

# ===== IDE / 编辑器 =====
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ===== 测试覆盖率 =====
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
pytestdebug.log

# ===== Jupyter Notebook =====
.ipynb_checkpoints
*.ipynb

# ===== Docker =====
# 不要忽略 Dockerfile 和 docker-compose.yml
# 但忽略构建缓存
.docker/

# ===== 临时文件 =====
*.tmp
*.temp
*.bak
*.backup
*.swp
*~

# ===== 操作系统 =====
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# ===== 文档生成 =====
docs/_build/
site/

# ===== 其他 =====
# 大文件
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# 证书文件（如果使用 SSL）
*.pem
*.key
*.crt
ssl/
nginx/ssl/
backend/unsloth_compiled_cache/

# ===== Claude Code =====
.claude/settings.local.json
.claude/settings.json
.claudecode/

# ===== 临时文件 =====
backend/nohup.out
backend/printf
docs/superpowers/

# ===== Word 文档 =====
*.docx
