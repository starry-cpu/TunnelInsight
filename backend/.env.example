# ===================================
# TunnelInsight 后端环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ===================================

# 数据库配置（MySQL）
DATABASE_URL=mysql+aiomysql://tunnel_defect:你的密码@localhost:3306/tunnel_insight
DB_USER=tunnel_defect
DB_PASSWORD=你的数据库密码
DB_NAME=tunnel_insight
DB_HOST=localhost
DB_PORT=3306

# 安全密钥（请使用以下命令生成新的密钥）：
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=请替换为你生成的密钥
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_SECONDS=86400

# API 配置
API_V1_PREFIX=/api/v1
PROJECT_NAME=TunnelInsight
VERSION=1.0.0

# CORS（修改为你的前端访问地址）
BACKEND_CORS_ORIGINS=["http://localhost:6006"]

# AI 模型
MODEL_PATH=./models/qwen2.5-vl-defect
BASE_MODEL_NAME=unsloth/Qwen2.5-VL-7B-Instruct-unsloth-bnb-4bit
INFERENCE_TIMEOUT=120

# RAG 服务配置（LightRAG，可选）
RAG_SERVICE_URL=http://localhost:9621
RAG_ENABLED=false
RAG_TIMEOUT=30.0

# 文件上传
MAX_UPLOAD_SIZE=20971520
UPLOAD_DIR=./uploads

# 邮件（可选，用于密码重置功能）
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=TunnelInsight
SMTP_USE_TLS=true

# 前端地址（用于邮件中的链接）
FRONTEND_URL=http://localhost:6006

# 生产环境
ENVIRONMENT=production
